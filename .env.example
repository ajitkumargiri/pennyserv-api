APP_NAME=PennyServ API
APP_VERSION=0.1.0
APP_ENV=local
APP_DEBUG=false

API_PREFIX=/api/v1
OPENAPI_URL=/openapi.json
DOCS_URL=/docs
REDOC_URL=/redoc

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pennyserv
DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pennyserv
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

READINESS_CHECK_DATABASE=false
READINESS_CHECK_REDIS=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

DATA_PLATFORM_BASE_URL=http://localhost:9000
DATA_PLATFORM_API_KEY=
DATA_PLATFORM_TIMEOUT_SECONDS=10
